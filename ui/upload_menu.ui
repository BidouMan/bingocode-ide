   <property name="styleSheet">
    <string notr="true">/* 1. 菜单主体：极致瘦身后的胶囊风格 */
QFrame#menu_frame {
    /* 使用你指定的品牌绿 */
    background-color: #53AA66; 
    
    /* 30px 宽度的圆角半径应为 15px 才能形成正圆半圆 */
    border-top-left-radius: 15px;
    border-top-right-radius: 15px;
    
    /* 底部也设为圆角，增加悬浮感 */
    border-bottom-left-radius: 15px;
    border-bottom-right-radius: 15px;
    
    border: none;
}

/* 2. 内部按钮：针对 20px 图标优化 */
QFrame#menu_frame QPushButton {
    background-color: transparent;
    border: none;
    /* 极致紧凑的边距 */
    padding: 6px 0px; 
    margin: 0px;
}

/* 3. 按钮悬停：淡白色高亮 */
QFrame#menu_frame QPushButton:hover {
    background-color: rgba(255, 255, 255, 0.4);
    /* 悬停高亮也要做成圆角，适配 30px 宽度 */
    border-radius: 12px;
}

/* 4. 站位容器：设为同样的绿色，实现完美重叠 */
QWidget#widget {
    background-color: #53AA66;
    /* 底部圆角必须和父容器一致 */
    border-bottom-left-radius: 15px;
    border-bottom-right-radius: 15px;
    border: none;
}</string>
