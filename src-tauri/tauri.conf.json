{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "BingoCode IDE",
  "version": "0.2.0",
  "identifier": "com.bingocode.ide",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "BingoCode IDE",
        "width": 1000,
        "height": 650,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "titleBarStyle": "Transparent",
        "hiddenTitle": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [],
    "resources": [
      "../engine/*.py",
      "../engine/models/**",
      "../engine/assets/**"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
